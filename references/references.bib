  file = {/home/veinmahzy/Zotero/storage/TI3SJW5Y/Shen and Hu - 2025 - Smart City Governance Based on Multimodal Large-Scale Models.pdf}
}

@article{siretPublicComplainingBlessing2022,
  title = {Public Complaining: {{A}} Blessing in Disguise? {{Educational}} Calling as a Benevolent Process That Gives Consumers Voice on Brands' Social Media},
  shorttitle = {Public Complaining},
  author = {Siret, Iris and Sabadie, William},
