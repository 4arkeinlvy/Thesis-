\contentsline {figure}{\numberline {4.1}{\ignorespaces Distribusi sembilan instansi (dinas) pada set train.}}{118}{figure.caption.63}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces Ablasi modalitas pada CatBoost dan CatBoost+PGS.}}{121}{figure.caption.68}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Perbandingan akurasi dan macro F1 dengan dan tanpa PGS.}}{122}{figure.caption.70}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Heatmap macro F1 pada matrix grid pasangan encoder.}}{125}{figure.caption.72}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces Alur inti pelaporan pada perangkat Android fisik: pengambilan foto, narasi, dan akuisisi lokasi GPS (a); layar tinjauan AI yang menampilkan instansi prediksi beserta \textit {confidence} ($88\%$), peringkat prediksi alternatif, instansi tujuan terdekat dengan estimasi jarak, dan opsi koreksi kategori manual (b); serta daftar riwayat laporan beserta status terkini (c). Galeri lengkap seluruh layar disajikan pada Lampiran~\ref {app:ui-mockup}.}}{128}{figure.caption.74}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces Skema basis data yang ter-deploy pada Supabase (hasil visualisasi Supabase Studio): tabel publik aplikasi setelah normalisasi, yaitu akar agregat \texttt {reports} dengan tabel anak \texttt {report\_evidence}, \texttt {report\_assignments}, \texttt {report\_history}, \texttt {report\_sla}, dan registri \texttt {agencies}. Rancangan konseptualnya beserta mekanisme proyeksi-baca disajikan pada Gambar~\ref {fig:db-schema}.}}{129}{figure.caption.75}%
\contentsline {figure}{\numberline {4.7}{\ignorespaces Tampilan peran Moderator atau \textit {Super Admin}: antrean global ``All agencies'' yang menggabungkan laporan dari seluruh instansi dengan tapis instansi dan panel \textit {triage} (a); serta layar registri instansi (CRUD atas tabel \texttt {agencies}) yang memuat nama kantor, kategori, koordinat, penanda aktif, dan aksi pemuatan ulang server perutean (b).}}{131}{figure.caption.76}%
\contentsline {figure}{\numberline {4.8}{\ignorespaces Distribusi skor SUS individual ($n = 30$) dengan penanda rata-rata, pita interval kepercayaan 95\%, dan garis \textit {benchmark} industri 68.}}{137}{figure.caption.81}%
\contentsline {figure}{\numberline {4.9}{\ignorespaces Posisi skor SUS rata-rata SmartCityApps (71,6) pada skala interpretasi baku: keberterimaan \citep {bangorDeterminingWhatIndividual2009}, kata sifat \citep {bangorEmpiricalEvaluation2008}, dan nilai huruf \citep {lewisSauroPastPresent2018}. Garis galat menunjukkan interval kepercayaan 95\%.}}{137}{figure.caption.82}%
\contentsline {figure}{\numberline {4.10}{\ignorespaces Kontribusi skor per pernyataan SUS (skala 0--4 terkoreksi-arah), diurutkan dari pernyataan terlemah ke terkuat. Pernyataan dengan kontribusi di bawah titik tengah (2,5) menandai aspek yang paling perlu diperbaiki.}}{138}{figure.caption.84}%
\contentsline {figure}{\numberline {4.11}{\ignorespaces \textit {Confusion matrix} ternormalisasi (per baris) pada set uji untuk konfigurasi terbaik DINOv3 large + mE5 large + CatBoost+PGS.}}{140}{figure.caption.85}%
