\contentsline {figure}{\numberline {3.1}{\ignorespaces Diagram alir kerangka berpikir penelitian secara keseluruhan.}}{54}{figure.caption.13}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Diagram alir tahap akuisisi data dari \textit {web scraping} portal CRM Jakarta sampai pembagian data stratifikasi.}}{55}{figure.caption.14}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces Fase persiapan pelatihan: setup pod RunPod, instalasi dependensi, dan ekstraksi \textit {embedding} citra dan teks ke berkas \textit {cache}.}}{56}{figure.caption.15}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces Fase eksperimen: pelatihan \textit {classifier head} CatBoost+PGS untuk 16 pasangan \textit {encoder}, pemilihan model terbaik, dan ekspor ONNX dengan validasi paritas numerik.}}{57}{figure.caption.16}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces Diagram aktivitas tahap \textit {deployment} mencakup ekspor ONNX, server FastAPI untuk inferensi server-side, aplikasi Android SmartCityApps sebagai klien, perutean instansi terdekat, dan pengujian sistem.}}{59}{figure.caption.17}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces Contoh struktur data multimodal: foto ojek parkir di area halte bus, narasi singkat warga, dan label \textit {Dinas Perhubungan}. Tiga kolom yang ditampilkan adalah kolom \textit {Gambar}, kolom \textit {Laporan}, dan kolom \textit {Label}.}}{62}{figure.caption.20}%
\contentsline {figure}{\numberline {3.7}{\ignorespaces Alur inferensi multimodal server-side dari citra dan teks ke prediksi 9 instansi, confidence, dan routing instansi terdekat berdasarkan koordinat.}}{77}{figure.caption.26}%
\contentsline {figure}{\numberline {3.8}{\ignorespaces Diagram komponen dan deployment SmartCityApps: klien Android, backend FastAPI untuk inferensi server-side, HuggingFace sebagai model registry/storage, dan Supabase.}}{80}{figure.caption.27}%
\contentsline {figure}{\numberline {3.9}{\ignorespaces \textit {Activity diagram} pengelolaan registri instansi oleh super admin: penyuntingan data dengan penegakan RLS \texttt {agencies\_write\_super\_admin}, lalu pemuatan ulang \textit {cache} server inferensi melalui \texttt {/reload-agencies} dengan \textit {fallback} ke \texttt {agencies\_seed.json} bila basis data tidak terjangkau.}}{84}{figure.caption.29}%
\contentsline {figure}{\numberline {3.10}{\ignorespaces Skema basis data Supabase ternormalisasi: akar agregat \texttt {reports} dengan tabel anak bukti, penugasan, audit, dan SLA, serta proyeksi-baca yang disinkronkan \textit {trigger} untuk klien \textit {Realtime}.}}{85}{figure.caption.30}%
\contentsline {figure}{\numberline {3.11}{\ignorespaces \textit {Use case diagram} SmartCityApps dengan prediksi server-side, confidence level, routing instansi terdekat, dan bukti penyelesaian.}}{88}{figure.caption.31}%
\contentsline {figure}{\numberline {3.12}{\ignorespaces \textit {Activity diagram} siklus laporan SmartCityApps dari pelaporan, inferensi server-side, routing instansi terdekat, sampai bukti penyelesaian.}}{90}{figure.caption.33}%
\contentsline {figure}{\numberline {3.13}{\ignorespaces \textit {Class diagram} bagian 1 dari 5, lapisan layanan inti: abstraksi \texttt {AiClassificationService} dengan implementasi \textit {cloud} dan \textit {demo}, klien \texttt {CloudClassificationService} beserta DTO \texttt {CloudPrediction}, serta layanan lokasi dan media.}}{91}{figure.caption.34}%
\contentsline {figure}{\numberline {3.14}{\ignorespaces \textit {Class diagram} bagian 2 dari 5, modul otentikasi: \texttt {AuthRepository} berbasis Supabase, model \texttt {UserProfile}, dan hierarki \textit {sealed} \texttt {UserRole} dengan tiga peran (\texttt {Citizen}, \texttt {AgencyAdmin}, \texttt {SuperAdmin}).}}{92}{figure.caption.35}%
\contentsline {figure}{\numberline {3.15}{\ignorespaces \textit {Class diagram} bagian 3 dari 5, modul laporan: \texttt {CreateReportController}, \texttt {ReportsRepository} dengan antarmuka tersegregasi \texttt {ReportsReader}/\texttt {ReportAdminActions}, dan strategi cakupan \textit {sealed} \texttt {ReportsScope} per peran pengguna.}}{92}{figure.caption.36}%
\contentsline {figure}{\numberline {3.16}{\ignorespaces \textit {Class diagram} bagian 4 dari 5, model domain: \texttt {CityReport}, \texttt {AiPrediction}, \texttt {ReportAssignment}, \texttt {ReportHistoryEntry}, \texttt {ReportLocationData}, serta enum \texttt {IssueCategory} (sembilan kelas) dan \texttt {ReportStatus}.}}{93}{figure.caption.37}%
\contentsline {figure}{\numberline {3.17}{\ignorespaces \textit {Class diagram} bagian 5 dari 5, modul administrasi registri instansi: \texttt {AgencyRegistryScreen} dan \texttt {AgencyRegistryRepository} (operasi CRUD ke tabel \texttt {agencies} serta pemuatan ulang \textit {cache} server melalui \texttt {/reload-agencies}), beserta model \texttt {Agency} dan \texttt {AgencyReloadResult}. Penulisan dibatasi peran super admin melalui RLS \texttt {agencies\_write\_super\_admin}.}}{94}{figure.caption.38}%
\contentsline {figure}{\numberline {3.18}{\ignorespaces \textit {Sequence diagram} pengiriman laporan, inferensi server-side, penyimpanan assignment, dan bukti penyelesaian.}}{95}{figure.caption.39}%
