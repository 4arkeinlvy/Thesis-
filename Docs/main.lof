\contentsline {figure}{\numberline {4.3}{\ignorespaces Perbandingan balanced accuracy dan macro F1 dengan dan tanpa PGS.}}{110}{figure.caption.49}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Heatmap macro F1 pada matrix grid pasangan encoder.}}{113}{figure.caption.51}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces Alur inti pelaporan: pengambilan foto, narasi, dan lokasi (a); layar tinjauan AI yang menampilkan instansi prediksi, \textit {confidence}, peringkat prediksi teratas, instansi tujuan terdekat, dan opsi koreksi kategori manual (b); serta daftar riwayat laporan beserta status (c). Galeri lengkap seluruh layar disajikan pada Lampiran~\ref {app:ui-mockup}.}}{115}{figure.caption.53}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces Skema basis data yang ter-deploy pada Supabase (hasil visualisasi Supabase Studio): tabel publik aplikasi setelah normalisasi, yaitu akar agregat \texttt {reports} dengan tabel anak \texttt {report\_evidence}, \texttt {report\_assignments}, \texttt {report\_history}, \texttt {report\_sla}, dan registri \texttt {agencies}. Rancangan konseptualnya beserta mekanisme proyeksi-baca disajikan pada Gambar~\ref {fig:db-schema}.}}{117}{figure.caption.54}%
\contentsline {figure}{\numberline {4.7}{\ignorespaces \textit {Confusion matrix} ternormalisasi (per baris) pada set uji untuk konfigurasi terbaik DINOv3 large + mE5 large + CatBoost+PGS.}}{123}{figure.caption.60}%
