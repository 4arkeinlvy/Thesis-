\contentsline {figure}{\numberline {A.1}{\ignorespaces Layar onboarding tiga halaman serta layar masuk dan registrasi akun terverifikasi.}}{145}{figure.caption.64}%
\contentsline {figure}{\numberline {A.2}{\ignorespaces Beranda warga dengan ringkasan status laporan dan peta laporan terdekat, serta layar buat laporan (ambil foto, narasi, dan lokasi).}}{145}{figure.caption.65}%
\contentsline {figure}{\numberline {A.3}{\ignorespaces Layar tinjauan hasil AI (instansi prediksi, \textit {confidence}, tiga prediksi teratas, instansi tujuan terdekat, dan koreksi kategori manual); daftar riwayat laporan beserta filter status; serta detail laporan dengan \textit {timeline} status dari \textit {submitted} hingga \textit {resolved}.}}{146}{figure.caption.66}%
\contentsline {figure}{\numberline {A.4}{\ignorespaces Layar peta laporan dengan pin lokasi laporan dan filter status di atas ubin peta OpenStreetMap, layar profil pengguna, dan pengaturan aplikasi.}}{147}{figure.caption.67}%
\contentsline {figure}{\numberline {A.5}{\ignorespaces Layar pemulihan kata sandi melalui surel.}}{147}{figure.caption.68}%
\contentsline {figure}{\numberline {A.6}{\ignorespaces Dasbor antrean operator instansi yang hanya menampilkan laporan ter-\textit {routing} sesuai peran melalui \textit {Row Level Security}, serta profil operator yang memuat lingkup instansi yang ditugaskan.}}{148}{figure.caption.69}%
\contentsline {figure}{\numberline {A.7}{\ignorespaces Alur penanganan laporan oleh operator instansi: bilah aksi pembaruan status (\textit {verify}, \textit {reject}, \textit {in progress}, \textit {resolved}) saat operator membuka laporan instansinya (a); \textit {sheet} unggah bukti penyelesaian yang wajib diisi sebelum laporan dapat ditandai selesai (b); dan tampilan laporan yang telah selesai dengan \textit {timeline} status lengkap beserta bukti penyelesaian yang tersimpan (c).}}{149}{figure.caption.70}%
