\contentsline {figure}{\numberline {A.1}{\ignorespaces Layar onboarding tiga halaman serta layar masuk dan registrasi akun terverifikasi.}}{130}{figure.caption.55}%
\contentsline {figure}{\numberline {A.2}{\ignorespaces Beranda warga dengan ringkasan status laporan dan peta laporan terdekat, serta layar buat laporan (ambil foto, narasi, dan lokasi).}}{130}{figure.caption.56}%
\contentsline {figure}{\numberline {A.3}{\ignorespaces Layar tinjauan hasil AI (instansi prediksi, \textit {confidence}, tiga prediksi teratas, instansi tujuan terdekat, dan koreksi kategori manual); daftar riwayat laporan beserta filter status; serta detail laporan dengan \textit {timeline} status dari \textit {submitted} hingga \textit {resolved}.}}{131}{figure.caption.57}%
\contentsline {figure}{\numberline {A.4}{\ignorespaces Layar peta laporan dengan pin lokasi laporan dan filter status di atas ubin peta OpenStreetMap, layar profil pengguna, dan pengaturan aplikasi.}}{132}{figure.caption.58}%
