@startuml component_diagram
!theme plain
skinparam backgroundColor white
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 11
skinparam componentStyle uml2
skinparam component {
    BackgroundColor #ecf0f1
    BorderColor #2c3e50
    FontColor #2c3e50
}
skinparam node {
    BackgroundColor #ffffff
    BorderColor #2c3e50
    FontColor #2c3e50
}
skinparam database {
    BackgroundColor #d6eaf8
    BorderColor #2c3e50
    FontColor #2c3e50
}
skinparam cloud {
    BackgroundColor #fef9e7
    BorderColor #b7950b
    FontColor #2c3e50
}
skinparam shadowing false
skinparam roundCorner 8

title Deployment dan Component Diagram SmartCityApps dengan Server-Side Inference

node "Android Device" <<client>> {
  artifact "SmartCityApps.apk" as Apk
  component "SmartCityApps\nFlutter UI" as App
  component "Camera / Gallery / GPS" as DeviceServices
}

node "Docker Container" <<server>> {
  component "Ngrok Tunnel" as Ngrok
}

node "Docker Container" <<server>> {
  component "FastAPI Backend Service" as Backend

  component "Server-Side Inference Module" as Inference {
    artifact "Image Preprocessing Pipeline" as Preprocess
    artifact "DINOv3 Image Encoder ONNX" as ImgModel
    artifact "mE5 Text Encoder ONNX" as TxtModel
    artifact "CatBoost+PGS Multiclass Model" as Classifier
    artifact "Confidence Score Calculator" as Confidence
  }

  component "Nearest Agency Routing Service" as Routing
}

cloud "HuggingFace" <<external service>> {
  artifact "Model Registry /\nModel Storage" as HFModel
}

cloud "Supabase Managed Backend" as Supabase {
  database "PostgreSQL\nprofiles, reports,\nreport_history" as Db
  component "Storage\nreport-images bucket" as Storage
  component "Auth + RLS" as Auth
}

Apk --> App
App --> DeviceServices : camera + latitude/longitude
App --> Ngrok : HTTPS/JSON\nimage + description + lat/lon
Ngrok --> Backend : forward API request
Backend --> Preprocess : validate + preprocess image/text
Preprocess --> ImgModel
Preprocess --> TxtModel
ImgModel --> Classifier : image embedding
TxtModel --> Classifier : text embedding
Classifier --> Confidence : class probabilities
Confidence --> Backend : predicted class + confidence
Backend --> Routing : class + report coordinate
Routing --> Backend : nearest agency + distance
Backend --> App : prediction + confidence\n+ nearest agency
App --> Storage : upload report / evidence photo
App --> Db : save report,\nprediction, assignment,\nstatus, evidence metadata
App --> Auth : sign-in and role policy
HFModel --> ImgModel : model artifact loaded\nat startup/deployment
HFModel --> TxtModel : model artifact loaded\nat startup/deployment
HFModel --> Classifier : classifier artifact loaded\nat startup/deployment

note right of Backend
Inference is performed on the FastAPI server.
SmartCityApps does not run the ML model locally.
end note

note bottom of Routing
Routing uses latitude and longitude to assign
the report to the nearest relevant agency.
end note

@enduml
