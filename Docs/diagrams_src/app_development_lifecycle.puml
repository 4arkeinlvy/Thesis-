@startuml app_development_lifecycle
!theme plain
skinparam backgroundColor white
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 11
skinparam activity {
    BackgroundColor #ffffff
    BorderColor #2c3e50
    DiamondBackgroundColor #fef9e7
    DiamondBorderColor #b7950b
    StartColor #27ae60
    EndColor #c0392b
    ArrowColor #34495e
    FontColor #2c3e50
}
skinparam partition {
    BackgroundColor #fafafa
    BorderColor #95a5a6
    FontColor #1b2631
}
skinparam shadowing false
skinparam roundCorner 12

title Siklus Pengembangan Aplikasi SmartCityApps

start

partition "1. Analisis Kebutuhan" {
    :Pemetaan kebutuhan pengguna pada tiga peran:\nWarga Pelapor, Operator Instansi, Moderator;
    :Identifikasi kebutuhan fungsional\n(pelaporan multimodal, klasifikasi AI,\nperutean instansi, otentikasi peran);
    :Identifikasi kebutuhan non-fungsional\n(latensi inferensi, ketersediaan jaringan,\nukuran paket aplikasi, privasi data);
    :Studi sistem CRM Jakarta dan SP4N-LAPOR!\nuntuk konteks operasional;
}

partition "2. Perancangan Sistem" {
    :Perancangan arsitektur klien-server:\nFlutter (Android) + FastAPI + Supabase;
    :Penyusunan use case diagram\n(3 aktor utama, 4 aktor sistem,\n~30 use cases);
    :Penyusunan class diagram\nlapisan service dan repositori;
    :Penyusunan sequence diagram\nalur permintaan POST /predict;
    :Perancangan ERD basis data Supabase\n(profiles, reports, report_history);
    :Definisi routing instansi terdekat\nberdasarkan prediksi 9 instansi + lat/lon;
}

partition "3. Perancangan Antarmuka" {
    :Penyusunan information architecture\n(splash, login, home, create report,\nAI review, history, map, profile,\nadmin inbox);
    :Mockup setiap layar berbasis Material Design 3\ndengan fokus pada alur Buat Laporan;
    :Penetapan komponen reusable\n(card laporan, peta dengan pin,\nbottom sheet rekomendasi);
}

partition "4. Implementasi Backend (FastAPI)" {
    :Implementasi endpoint /health dan /predict;
    :Pemuatan tiga ONNX session pada startup;
    :Wrapping pipeline fusi awal:\npreprocess citra → encoder DINOv3 →\npreprocess teks → encoder mE5 →\nkonkatenasi 2048d → classifier CatBoost+PGS;
    :Kontainerisasi via Dockerfile dan\nDocker Compose untuk reproducibility;
}

partition "5. Implementasi Frontend (Flutter)" {
    :Inisialisasi project Flutter dengan\nstate management Riverpod dan\nnavigasi GoRouter (deklaratif);
    :Implementasi layanan inti:\nAiClassificationService, CloudClassificationService,\nLocationService, MediaService;
    :Implementasi 17 layar pada\nlib/features/<feature>/<screen>.dart;
    :Implementasi fitur:\nkamera, galeri, GPS, peta, pelaporan,\ntinjauan AI, riwayat, profil,\ndashboard admin;
}

partition "6. Integrasi Backend dan Layanan" {
    :Integrasi Supabase Auth dengan\nAuthFlowType.pkce;
    :Implementasi Row Level Security\npada tabel profiles, reports, report_history;
    :Integrasi Supabase Storage\nuntuk berkas gambar laporan;
    :Implementasi Supabase Realtime\nuntuk update status lintas peran;
    :Konfigurasi CRM_API_URL pada AppConfig\nuntuk koneksi ke server FastAPI;
}

partition "7. Pengujian" {
    :Pengujian unit pada layanan klasifikasi\n(CloudAiClassificationService,\nDemoAiClassificationService);
    :Pengujian integrasi alur Buat Laporan\n(camera → GPS → predict → submit);
    :Pengujian end-to-end pada perangkat\nAndroid fisik dengan adb reverse port forward;
    :Validasi paritas numerik PyTorch ↔ ONNX\npada 100 sampel set uji;
    :Evaluasi akurasi: macro F1, balanced accuracy,\nconfusion matrix pada 9 instansi;
}

partition "8. Deployment" {
    :Build APK release Flutter;
    :Deploy server FastAPI ke RunPod / VPS\nmenggunakan Docker image;
    :Deploy skema dan RPC Supabase\nmelalui supabase/migrations;
    :Pengaturan kebijakan retry, timeout,\ndan circuit breaker pada klien;
    :Distribusi prototipe ke pengguna uji\n(Warga, Operator, Moderator);
}

stop

@enduml
