@startuml class_diagram_flutter
!include _thesis_style.puml

hide empty members
skinparam dpi 150
skinparam linetype polyline
skinparam nodesep 14
skinparam ranksep 26
skinparam packageStyle rectangle

' ============================================================
' Class diagram (production view) of the SmartCityApps Flutter
' client. Reflects the actual Riverpod + GoRouter + Supabase
' code base: interface-segregated repositories, sealed role and
' scope hierarchies, the cloud classification service stack, and
' the create-report controller. Domain models map 1:1 to the
' Supabase `reports` / `report_history` / `profiles` tables.
' ============================================================

package "features.auth" <<Modul Otentikasi>> {
    class AuthRepository {
        -client: SupabaseClient
        +signUp(...) : Future<SignUpResult>
        +signIn(email, password) : Future<void>
        +signOut() : Future<void>
        +fetchCurrentUserProfile() : Future<UserProfile?>
        +authStateChanges() : Stream<LocalAuthSession?>
    }
    class SignUpResult <<DTO>> {
        +user: UserProfile?
        +requiresEmailConfirmation: bool
    }
    class LocalAuthSession <<value>> {
        +userId: String
    }
    class UserProfile <<model>> {
        +id: String
        +fullName: String
        +email: String
        +role: String
        +assignedAgency: IssueCategory?
    }
    abstract class UserRole <<sealed>> {
        +canSubmitReports: bool
        +canModerateReports: bool
        +canReassignAgency: bool
        +{static} fromProfile(p: UserProfile) : UserRole
    }
    class Citizen <<role>>
    class AgencyAdmin <<role>> {
        +agency: IssueCategory
    }
    class SuperAdmin <<role>>
}

package "core.services" <<Layanan Inti>> {
    interface AiClassificationService <<interface>> {
        +classify(image, description, location) : Future<AiPrediction>
    }
    class CloudAiClassificationService {
        -client: CloudClassificationService
        +classify(...) : Future<AiPrediction>
    }
    class DemoAiClassificationService {
        +classify(...) : Future<AiPrediction>
    }
    class CloudClassificationService {
        +baseUrl: String
        +classify(...) : Future<CloudPrediction>
        +healthCheck() : Future<bool>
    }
    class CloudPrediction <<DTO>> {
        +predictedDinasId: int
        +confidence: double
        +allProbabilities: Map
        +reviewRequired: bool
        +assignment: ReportAssignment?
    }
    class LocationService {
        +getCoordinates() : Future<Position>
        +reverseGeocode(...) : Future<String>
    }
    class MediaService {
        +pickFromCamera() : Future<XFile?>
        +pickFromGallery() : Future<XFile?>
    }
}

package "features.reports" <<Modul Laporan>> {
    class CreateReportController <<Notifier>> {
        -aiService: AiClassificationService
        -reportsRepository: ReportsRepository
        +classifyImage() : Future<void>
        +updateCategory(c: IssueCategory) : void
        +submit() : Future<void>
    }
    class CreateReportState <<state>> {
        +prediction: AiPrediction?
        +selectedCategory: IssueCategory?
        +location: ReportLocationData?
        +canSubmit: bool
    }
    interface ReportsReader <<interface>> {
        +watchByUser(userId) : Stream<List<CityReport>>
        +watchByCategory(c) : Stream<List<CityReport>>
        +watchAll() : Stream<List<CityReport>>
        +watchHistory(id) : Stream<List<ReportHistoryEntry>>
    }
    interface ReportAdminActions <<interface>> {
        +verify(id, note) : Future<CityReport>
        +markResolved(id, photo, note) : Future<CityReport>
        +reject(id, reason) : Future<CityReport>
        +reassign(id, newAgency, note) : Future<CityReport>
    }
    class ReportsRepository {
        -client: SupabaseClient
        +submitReport(...) : Future<CityReport>
    }
    abstract class ReportsScope <<sealed>> {
        +watch(r: ReportsReader) : Stream<List<CityReport>>
        +{static} forRole(role, userId) : ReportsScope
    }
    class CitizenScope <<scope>>
    class AgencyScope <<scope>>
    class GlobalScope <<scope>>

    class CityReport <<model>> {
        +id: String
        +category: IssueCategory
        +aiConfidence: double
        +aiProbabilities: Map
        +status: ReportStatus
        +assignment: ReportAssignment?
        +{static} fromMap(map) : CityReport
    }
    class ReportHistoryEntry <<model>> {
        +reportId: String
        +status: ReportStatus
        +note: String
    }
    class AiPrediction <<model>> {
        +category: IssueCategory
        +confidence: double
        +assignment: ReportAssignment?
        +topPredictions(n) : List
    }
    class ReportAssignment <<model>> {
        +agencyId: String
        +agencyCategory: IssueCategory
        +distanceMeters: double
    }
    class ReportLocationData <<model>> {
        +latitude: double
        +longitude: double
        +address: String
    }
    enum IssueCategory <<9 kelas target>> {
        dinasBinaMarga
        satpolPP
        dinasPerhubungan
        kelurahan
        dinasPertamananHutan
        dinasSDA
        dinasCiptaKarya
        badanBUMD
        instansiLain
        --
        +dbValue / cloudId / label
    }
    enum ReportStatus {
        submitted
        verified
        inProgress
        resolved
        rejected
    }
}

' ---- auth + roles ----
AuthRepository ..> UserProfile
AuthRepository ..> SignUpResult
AuthRepository ..> LocalAuthSession
UserRole ..> UserProfile : fromProfile()
UserRole <|-- Citizen
UserRole <|-- AgencyAdmin
UserRole <|-- SuperAdmin
AgencyAdmin --> IssueCategory
UserProfile --> "0..1" IssueCategory : assignedAgency

' ---- core.services realizations / collaborations ----
AiClassificationService <|.. CloudAiClassificationService
AiClassificationService <|.. DemoAiClassificationService
CloudAiClassificationService --> CloudClassificationService
CloudClassificationService ..> CloudPrediction : creates
CloudPrediction *-- "0..1" ReportAssignment
AiClassificationService ..> AiPrediction : returns

' ---- create-report controller ----
CreateReportController *-- CreateReportState
CreateReportController --> AiClassificationService
CreateReportController --> ReportsRepository
CreateReportState o-- "0..1" AiPrediction
CreateReportState o-- "0..1" ReportLocationData

' ---- reports repository (interface segregation) ----
ReportsRepository ..|> ReportsReader
ReportsRepository ..|> ReportAdminActions
ReportsRepository ..> CityReport : maps rows
ReportsRepository ..> ReportHistoryEntry

' ---- role-scoped read strategy ----
ReportsScope <|-- CitizenScope
ReportsScope <|-- AgencyScope
ReportsScope <|-- GlobalScope
ReportsScope ..> ReportsReader : reads via
ReportsScope ..> UserRole : forRole()
AgencyScope --> IssueCategory

' ---- domain model relations ----
AiPrediction --> IssueCategory
AiPrediction o-- "0..1" ReportAssignment
ReportAssignment --> IssueCategory
CityReport *-- IssueCategory
CityReport *-- ReportStatus
CityReport o-- "0..1" ReportAssignment
ReportHistoryEntry --> ReportStatus

' ---- force vertical stacking of the three packages ----
UserRole -[hidden]down-> AiClassificationService
MediaService -[hidden]down-> CreateReportController

note right of ReportsRepository
  Satu kelas merealisasikan dua antarmuka tersegregasi:
  **ReportsReader** (baca: warga & admin) dan
  **ReportAdminActions** (mutasi: moderator, super-admin).
  Persistensi: Supabase Postgres + Storage via
  SupabaseClient (RPC update_report_status).
end note

@enduml
