@startuml usecase_smart_city_reporter
!theme plain
skinparam backgroundColor white
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam usecase {
    BackgroundColor #ffffff
    BorderColor #2c3e50
    ArrowColor #34495e
    FontColor #2c3e50
}
skinparam actor {
    BackgroundColor #ecf0f1
    BorderColor #2c3e50
    FontColor #2c3e50
}
skinparam package {
    BackgroundColor #fafafa
    BorderColor #2c3e50
    FontColor #2c3e50
}
skinparam shadowing false
skinparam roundCorner 14
left to right direction

actor "Warga Pelapor" as Citizen
actor "Petugas Instansi" as Officer
actor "Admin" as Admin
actor "Machine Learning Model\n(Server-Side)" as ML
actor "Nearest Agency\nRouting Service" as Routing
actor "Supabase\nDB + Storage" as Supabase
actor "Kamera / Galeri / GPS" as Device

rectangle "SmartCityApps System" {
  package "Pelaporan Warga" {
    usecase "Membuat Laporan" as UCCreate
    usecase "Mengunggah Foto Laporan" as UCPhoto
    usecase "Mengirim Latitude\n dan Longitude" as UCLocation
    usecase "Meninjau Hasil AI" as UCReview
    usecase "Mengoreksi Kategori" as UCEdit
    usecase "Menyimpan Laporan" as UCSave
    usecase "Melihat Status Laporan" as UCStatus
  }

  package "Backend FastAPI" {
    usecase "Preprocess Image/Text" as UCPreprocess
    usecase "Classify Report Category" as UCClassify
    usecase "Generate Confidence Level" as UCConfidence
    usecase "Route to Nearest Agency" as UCRoute
  }

  package "Petugas dan Admin" {
    usecase "Melihat Antrean Instansi" as UCInbox
    usecase "Update Status Laporan" as UCUpdate
    usecase "Upload Resolution\nEvidence Photo" as UCEvidence
    usecase "Manual Review\nLow Confidence Report" as UCManual
    usecase "Manage Agency Data" as UCAgency
  }
}

Citizen --> UCCreate
Citizen --> UCPhoto
Citizen --> UCLocation
Citizen --> UCReview
Citizen --> UCEdit
Citizen --> UCSave
Citizen --> UCStatus

Officer --> UCInbox
Officer --> UCUpdate
Officer --> UCEvidence
Officer --> UCManual
Admin --> UCAgency
Admin --> UCManual

UCCreate ..> UCPhoto : <<include>>
UCCreate ..> UCLocation : <<include>>
UCCreate ..> UCClassify : <<include>>
UCClassify ..> UCPreprocess : <<include>>
UCClassify ..> UCConfidence : <<include>>
UCClassify ..> UCRoute : <<include>>
UCUpdate ..> UCEvidence : <<include>>\nwhen selesai

Device --> UCPhoto
Device --> UCLocation
ML --> UCClassify
ML --> UCConfidence
Routing --> UCRoute
Supabase --> UCSave
Supabase --> UCEvidence
Supabase --> UCStatus

note right of ML
The ML actor represents
the FastAPI server-side
inference module, not
the Android app.
end note

@enduml
