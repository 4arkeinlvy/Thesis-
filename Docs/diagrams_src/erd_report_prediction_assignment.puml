@startuml erd_report_prediction_assignment
!include _thesis_style.puml

' ============================================================
' Normalized ERD for the Supabase (PostgreSQL) backend.
' Grounded in smart_city_reporter_app/supabase/schema.sql.
' reports = aggregate root; multi-valued/historical concerns live
' in child tables; flat columns on reports are a read-projection
' kept in sync by triggers (see note). Full column lists, enums,
' and RLS are detailed in Lampiran D.
' ============================================================

hide circle
skinparam dpi 200
skinparam linetype ortho
skinparam nodesep 32
skinparam ranksep 64
skinparam roundCorner 6
skinparam shadowing false
skinparam note {
  BackgroundColor #FEF9E7
  BorderColor #B7950B
  FontColor #5B4A06
}
skinparam legendBackgroundColor #F8F9F9
skinparam legendBorderColor #2E4053

' ===================== ENTITIES =====================

entity "auth.users" as Users #F4F6F7 {
  * id : uuid <<PK>>
  --
  email : text
}

entity "profiles" as Profiles #EBF5FB {
  * id : uuid <<PK, FK auth.users>>
  --
  * full_name : text
  * email : text
  * role : user_role
  assigned_agency : issue_category
  profile_photo_url : text
}

entity "reports  «aggregate root»" as Reports #FBFCFD {
  * id : uuid <<PK>>
  --
  * user_id : uuid <<FK profiles>>
  * category : issue_category
  * ai_prediction : text
  * ai_confidence : numeric(5,4)
  ai_probabilities : jsonb
  * latitude : double precision
  * longitude : double precision
  * address : text
  * visibility : report_visibility
  duplicate_of : uuid <<FK reports>>
  * status : report_status
  * created_at : timestamptz
}

entity "report_evidence" as Evidence #FEF5E7 {
  * id : uuid <<PK>>
  --
  * report_id : uuid <<FK reports>>
  * kind : evidence_kind
  * bucket : text
  * object_path : text
  uploaded_by : uuid <<FK profiles>>
}

entity "report_assignments" as Assignments #FDF2E9 {
  * id : uuid <<PK>>
  --
  * report_id : uuid <<FK reports>>
  agency_id : text <<FK agencies>>
  agency_category : issue_category
  distance_meters : double precision
  * status : assignment_status
  assigned_by : uuid <<FK profiles>>
}

entity "agencies" as Agencies #EBF5FB {
  * id : text <<PK>>
  --
  * name : text
  * category : issue_category
  latitude : double precision
  longitude : double precision
  is_active : boolean
}

entity "report_history" as History #F5EEF8 {
  * id : uuid <<PK>>
  --
  * report_id : uuid <<FK reports>>
  * status : report_status
  * note : text
  updated_by : uuid <<FK profiles>>
}

entity "report_sla" as Sla #EAFAF1 {
  * report_id : uuid <<PK, FK reports>>
  --
  first_response_due_at : timestamptz
  resolution_due_at : timestamptz
  breached_at : timestamptz
}

' ===================== RELATIONSHIPS =====================

Users    ||--||  Profiles
Profiles ||--o{  Reports     : "pelapor"
Reports  ||--o{  Evidence
Reports  ||--o{  Assignments
Reports  ||--||  Sla
Reports  ||--o{  History
Reports  ||--o{  Reports     : "duplicate_of"
Agencies ||--o{  Assignments

' ===================== SINGLE PROJECTION NOTE =====================

note bottom of Reports
**Proyeksi-baca (sinkron trigger)**
Kolom datar penugasan & bukti pada reports
(image_url, assigned_*, resolution_*) adalah
salinan baca yang disinkronkan trigger dari
report_assignments & report_evidence, agar
klien Realtime cukup membaca satu tabel.
Berkas: bucket + object_path (privat),
diakses via signed URL.
Rincian kolom, enum, dan RLS: Lampiran D.
end note

legend right
|= Notasi |= Arti |
| * | wajib (NOT NULL) |
| PK / FK | kunci primer / asing |
| crow's foot | relasi satu-ke-banyak |
endlegend

@enduml
