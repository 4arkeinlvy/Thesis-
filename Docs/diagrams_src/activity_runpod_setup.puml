@startuml activity_runpod_setup
!include _thesis_style.puml

|Mesin Lokal Peneliti|
start
:Persiapkan dataset Jakarta CRM\ndan kode pelatihan;
:Buat pod RunPod dengan GPU\nyang sesuai;
:Hubungkan ke pod via SSH;
:Sinkronisasi kode dan dataset\ndengan rsync;

|Pod RunPod (GPU)|
:Setup environment Python 3.11;
:Install requirements\n(PyTorch, CatBoost, ONNX,\nTransformers, scikit-learn);
:Verifikasi GPU dan CUDA;

partition "Ekstraksi Embedding (sekali per encoder)" {
    fork
        :Jalankan 04_extract_image_embeddings;
        :Image encoder DINOv3, DINOv2,\nEVA-02, atau Hiera large\n(frozen, eval mode);
        :Hasilkan vektor 1024d per sampel;
        :Simpan cache .npy ke\nartifacts/embeddings/image/;
    fork again
        :Jalankan 05_extract_text_embeddings;
        :Text encoder mE5 large,\nBGE-M3, IndoBERT,\natau Cendol-mT5\n(frozen, eval mode);
        :Hasilkan vektor 1024d per sampel;
        :Simpan cache .npy ke\nartifacts/embeddings/text/;
    end fork
}

:Cache embedding siap untuk\npelatihan classifier head;
stop

@enduml
